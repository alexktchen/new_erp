# ============================================================
# E2E reset · environment file (template)
# 複製成 scripts/e2e/.env.e2e 並填入實際值。
# .env.e2e 已在 .gitignore，不會被 commit。
# ============================================================

# Supabase pooler connection string（service role / postgres user）
# 從 Supabase Dashboard → Project Settings → Database → Connection string
#   Type=Session pooler、推薦用「Transaction」模式不行（DDL/TRUNCATE 需要 session）
# Format: postgresql://postgres.<project-ref>:<service-pwd>@<region>.pooler.supabase.com:5432/postgres
E2E_DB_URL=postgresql://postgres.anfyoeviuhmzzrhilwtm:REPLACE_ME@aws-x-xx-x.pooler.supabase.com:5432/postgres

# 防呆 host substring：URL 必須包含此字串才會被執行
E2E_EXPECTED_HOST=anfyoeviuhmzzrhilwtm
