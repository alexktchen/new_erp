# ============================================================
# E2E reset · environment file (template)
# 複製成 scripts/e2e/.env.e2e 並填入實際值。
# .env.e2e 已在 .gitignore，不會被 commit。
# ============================================================

# Supabase pooler 連線資訊
# 從 Supabase Dashboard → Project Settings → Database → Connection string
#   ★ 用 Session pooler（不是 Transaction）— TRUNCATE / DDL 需要 session
#
# 把 Dashboard 給的整段 URL 拆成下面四個變數，密碼有特殊字元也不用 URL-encode。
#
# 實際值範例（請依 dashboard 顯示的填）：
#   E2E_DB_HOST=aws-0-ap-northeast-1.pooler.supabase.com
#   E2E_DB_PORT=5432
#   E2E_DB_USER=postgres.anfyoeviuhmzzrhilwtm
#   E2E_DB_NAME=postgres
#   E2E_DB_PASSWORD=<從 dashboard 複製，原樣貼，不用 encode>

E2E_DB_HOST=aws-0-ap-northeast-1.pooler.supabase.com
E2E_DB_PORT=5432
E2E_DB_USER=postgres.anfyoeviuhmzzrhilwtm
E2E_DB_NAME=postgres
E2E_DB_PASSWORD=REPLACE_ME

# 防呆 host substring：host 必須包含此字串才會被執行
E2E_EXPECTED_HOST=anfyoeviuhmzzrhilwtm
